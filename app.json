{
  "expo": {
    "name": "ScholarCash",
    "slug": "scholarcash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/main-scholar-splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "bundleIdentifier": "com.scholarcash.app",
      "supportsTablet": true
    },

    "android": {
      "package": "com.scholarcash.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#E6F4FE"
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-font"
    ],

    "extra": {
      "eas": {
        "projectId": "54d766b2-5f1a-4afa-ac3a-b35cdcc25bc9"
      }
    }
  }
}
